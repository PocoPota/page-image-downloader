{
  "manifest_version": 3,
  "name": "Page Image Downloader",
  "version": "1.0.0",
  "description": "Download images from the current page as a ZIP file.",
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Download page images",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
